{
  "routes": [
    {
      "src": "/outsystems/(.*)",
      "dest": "https://personal-m9frao4j.outsystemscloud.com/TutorFinder_BookingProcess/rest/BookingProcess/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|ico|png|jpg|jpeg|svg|woff|woff2|ttf|map))",
