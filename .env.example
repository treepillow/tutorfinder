# Copy this file to .env and fill in the values

# Supabase PostgreSQL connection string
SUPABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_PASSWORD=your_supabase_password

# Stripe (optional — leave empty to use mock payment mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend email API (optional — leave empty to skip email sending)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
